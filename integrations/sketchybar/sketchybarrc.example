# Sysprite item — drop into your sketchybar config.
# Requires: Sysprite app running, and the `sysprite` binary available
# (either at /usr/local/bin/sysprite or inside the .app bundle).

sketchybar --add item sysprite right \
           --set sysprite \
                 update_freq=2 \
                 script="$CONFIG_DIR/plugins/sysprite.sh" \
                 icon.color=0xffffffff \
                 label.font="JetBrainsMono Nerd Font:Regular:12.0" \
                 icon.font="JetBrainsMono Nerd Font:Bold:14.0"

# Optional: split rows for cpu / mem / battery using individual fields
#
# for metric in cpu memory battery; do
#     sketchybar --add item sysprite.$metric right \
#                --set sysprite.$metric update_freq=2 \
#                      script="sysprite stats --$metric | xargs -I{} sketchybar --set \$NAME label='{}%'"
# done
